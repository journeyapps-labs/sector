{
  "compileOnSave": false,
  "compilerOptions": {
    "declaration": true,
    "jsx": "react",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "inlineSources": false,
    "lib": ["ES2020", "dom"],
    "importHelpers": true,
    "module": "es6",
    "target": "es2017",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "strict": false,
    "composite": true
  }
}
